# pgBackRest configuration — generated by Ansible, do not edit manually
[{{ postgres_pgbackrest_stanza }}]
pg1-path = /var/lib/postgresql/{{ postgres_version }}/main

[global]
# Local repo (SATA backup drive)
repo1-path = {{ postgres_pgbackrest_repo_local_path }}
repo1-retention-full = 7
repo1-retention-diff = 14

# S3 repo (offsite, WAL streaming)
repo2-type = s3
repo2-path = /pgbackrest/{{ postgres_pgbackrest_stanza }}
repo2-s3-bucket = {{ postgres_pgbackrest_s3_bucket }}
repo2-s3-region = {{ postgres_pgbackrest_s3_region }}
repo2-s3-endpoint = {{ postgres_pgbackrest_s3_endpoint }}
repo2-s3-key = {{ postgres_pgbackrest_s3_key }}
repo2-s3-key-secret = {{ postgres_pgbackrest_s3_secret }}
repo2-retention-full = 14
repo2-retention-diff = 30

log-level-console = info
log-level-file = detail
start-fast = y
compress-type = zst

[global:archive-push]
compress-level = 3
