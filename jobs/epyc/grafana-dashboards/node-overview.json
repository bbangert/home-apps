        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "system_uptime{host=\"$host\"}",
          "legendFormat": "Uptime"
        }
      ]
    },
    {
