        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "rate(net_bytes_recv{host=\"$host\", interface!=\"lo\"}[5m])",
          "legendFormat": "Recv {{interface}}"
