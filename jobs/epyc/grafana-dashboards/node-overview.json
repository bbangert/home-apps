    {
      "type": "row",
      "title": "System",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 10,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Load Average",
