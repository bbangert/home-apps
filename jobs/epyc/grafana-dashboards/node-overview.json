        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "rate(net_bytes_sent{host=\"$host\", interface!=\"lo\"}[5m])",
          "legendFormat": "Sent {{interface}}"
