    {
      "type": "row",
      "title": "Network",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 8,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Network Traffic",
      "description": "Network bytes received and sent per second by interface (excluding loopback)",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 9,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "Bps",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
