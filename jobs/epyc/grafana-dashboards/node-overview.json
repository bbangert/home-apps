{
  "__inputs": [
    {
      "name": "DS_VICTORIAMETRICS",
      "label": "VictoriaMetrics",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "uid": "node-overview",
  "title": "Node Overview",
  "description": "System overview for cluster nodes",
  "editable": false,
  "version": 1,
  "schemaVersion": 39,
  "tags": ["node", "system"],
  "timezone": "browser",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "epyc", "value": "epyc" },
        "datasource": { "type": "prometheus", "uid": "victoriametrics" },
        "definition": "label_values(cpu_usage_user, host)",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "host",
        "options": [],
        "query": { "qryType": 1, "query": "label_values(cpu_usage_user, host)" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "CPU & Memory",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "CPU Usage %",
      "description": "CPU usage broken down by user, system, and iowait",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 2,
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "%",
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "cpu_usage_user{host=\"$host\", cpu=\"cpu-total\"}",
          "legendFormat": "User"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "cpu_usage_system{host=\"$host\", cpu=\"cpu-total\"}",
          "legendFormat": "System"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "cpu_usage_iowait{host=\"$host\", cpu=\"cpu-total\"}",
          "legendFormat": "IOWait"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "description": "Memory usage breakdown: used, buffered, cached, with total as reference",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 3,
      "gridPos": { "h": 8, "w": 10, "x": 10, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "bytes",
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Total" },
            "properties": [
              { "id": "custom.stacking", "value": { "mode": "none" } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "mem_used{host=\"$host\"}",
          "legendFormat": "Used"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "mem_buffered{host=\"$host\"}",
          "legendFormat": "Buffered"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "mem_cached{host=\"$host\"}",
          "legendFormat": "Cached"
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "mem_total{host=\"$host\"}",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Memory %",
      "description": "Current memory usage percentage",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 4,
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 85, "color": "orange" },
              { "value": 95, "color": "red" }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "mem_used_percent{host=\"$host\"}",
          "legendFormat": "Memory %"
        }
      ]
    },
    {
      "type": "row",
      "title": "Disk",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 5,
      "panels": []
    },
    {
      "type": "gauge",
      "title": "Disk Usage % per Mount",
      "description": "Disk usage percentage grouped by mount path",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 6,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 85, "color": "orange" },
              { "value": 95, "color": "red" }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
