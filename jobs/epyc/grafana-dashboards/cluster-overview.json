    {
      "type": "stat",
      "title": "epyc",
      "description": "Uptime for epyc (Nomad server, 128 GB)",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0, "color": "green" }
            ]
          },
          "unit": "s",
          "noValue": "DOWN"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "system_uptime{host=\"epyc\"}",
          "legendFormat": "Uptime"
        }
      ]
    },
