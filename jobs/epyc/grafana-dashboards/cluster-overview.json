    {
      "type": "timeseries",
      "title": "CPU Usage %",
      "description": "CPU usage across all nodes",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 7,
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "%",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "100 - cpu_usage_idle{cpu=\"cpu-total\"}",
          "legendFormat": "{{ host }}"
        }
      ]
    },
