{
  "__inputs": [
    {
      "name": "DS_VICTORIAMETRICS",
      "label": "VictoriaMetrics",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    }
  ],
  "uid": "docker-containers",
  "title": "Docker Containers",
  "description": "Docker container metrics",
  "editable": false,
  "version": 1,
  "schemaVersion": 39,
  "tags": ["docker", "containers"],
  "timezone": "browser",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "epyc", "value": "epyc" },
        "datasource": { "type": "prometheus", "uid": "victoriametrics" },
        "definition": "label_values(docker_container_cpu_usage_percent, host)",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "host",
        "options": [],
        "query": { "qryType": 1, "query": "label_values(docker_container_cpu_usage_percent, host)" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "name": "container",
        "type": "query",
        "label": "Container",
        "datasource": { "type": "prometheus", "uid": "victoriametrics" },
        "query": "label_values(docker_container_cpu_usage_percent{host=\"$host\"}, container_name)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Container CPU %",
      "description": "CPU usage percentage per container",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "%",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "percent",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "docker_container_cpu_usage_percent{host=\"$host\", container_name=~\"$container\"}",
          "legendFormat": "{{container_name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container Memory Usage",
      "description": "Memory usage per container",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "docker_container_mem_usage{host=\"$host\", container_name=~\"$container\"}",
          "legendFormat": "{{container_name}}"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Container Memory %",
      "description": "Memory usage percentage per container",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 3,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 85, "color": "orange" },
              { "value": 95, "color": "red" }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "docker_container_mem_usage_percent{host=\"$host\", container_name=~\"$container\"}",
          "legendFormat": "{{container_name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container Network RX/TX",
      "description": "Network bytes received and transmitted per container",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "Bps",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "rate(docker_container_net_rx_bytes{host=\"$host\", container_name=~\"$container\"}[5m])",
          "legendFormat": "RX {{container_name}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "rate(docker_container_net_tx_bytes{host=\"$host\", container_name=~\"$container\"}[5m])",
          "legendFormat": "TX {{container_name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container Block I/O",
      "description": "Block I/O read and write bytes per container",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "Bps",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "rate(docker_container_blkio_io_service_bytes_recursive_read{host=\"$host\", container_name=~\"$container\"}[5m])",
          "legendFormat": "Read {{container_name}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "rate(docker_container_blkio_io_service_bytes_recursive_write{host=\"$host\", container_name=~\"$container\"}[5m])",
          "legendFormat": "Write {{container_name}}"
        }
      ]
    }
  ]
}
