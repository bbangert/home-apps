{
  "__inputs": [
    {
      "name": "DS_VICTORIAMETRICS",
      "label": "VictoriaMetrics",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "uid": "nomad-cluster",
  "title": "Nomad Cluster - epyc",
  "description": "Nomad client and cluster metrics for the epyc node",
  "editable": false,
  "version": 1,
  "schemaVersion": 39,
  "tags": ["nomad", "cluster", "epyc"],
  "timezone": "browser",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Allocations",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Running Allocations",
      "description": "Number of running allocations on the client",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" }
            ]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "nomad_client_allocs_running{host=\"epyc\"}",
          "legendFormat": "Running"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Blocked Allocations",
      "description": "Number of blocked allocations",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "nomad_client_allocs_blocked{host=\"epyc\"}",
          "legendFormat": "Blocked"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Migrating Allocations",
      "description": "Number of migrating allocations",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" }
            ]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "nomad_client_allocs_migrating{host=\"epyc\"}",
          "legendFormat": "Migrating"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Client Uptime",
      "description": "Nomad client uptime",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 5,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" }
            ]
          },
          "unit": "s",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "nomad_client_uptime{host=\"epyc\"}",
          "legendFormat": "Uptime"
        }
      ]
    },
    {
      "type": "row",
      "title": "Host Resources",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Host CPU % (Nomad)",
      "description": "Total host CPU usage as reported by Nomad client",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "%",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "nomad_client_host_cpu_total{host=\"epyc\"}",
          "legendFormat": "CPU Total"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Host Memory Used (Nomad)",
      "description": "Host memory usage as reported by Nomad client",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "nomad_client_host_memory_used{host=\"epyc\"}",
          "legendFormat": "Memory Used"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Host Disk Available (Nomad)",
      "description": "Available disk space as reported by Nomad client",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "id": 9,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 10737418240, "color": "yellow" },
              { "value": 53687091200, "color": "green" }
            ]
          },
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "nomad_client_host_disk_available{host=\"epyc\"}",
          "legendFormat": "Disk Available"
        }
      ]
    }
  ]
}
