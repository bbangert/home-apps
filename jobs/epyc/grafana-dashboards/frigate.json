{
  "__inputs": [
    {
      "name": "DS_VICTORIAMETRICS",
      "label": "VictoriaMetrics",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    }
  ],
  "uid": "frigate",
  "title": "Frigate NVR",
  "description": "Frigate camera, detector, and GPU metrics",
  "editable": false,
  "version": 1,
  "schemaVersion": 39,
  "tags": ["frigate", "nvr"],
  "timezone": "browser",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "victoriametrics"
        },
        "definition": "label_values(frigate_camera_camera_fps, camera)",
        "name": "camera",
        "includeAll": true,
        "multi": true,
        "query": {
          "query": "label_values(frigate_camera_camera_fps, camera)",
          "refId": "camera"
        },
        "refresh": 2,
        "type": "query",
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "title": "Camera FPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "fps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "frigate_camera_camera_fps{camera=~\"$camera\"}",
          "legendFormat": "{{camera}} - camera",
          "refId": "A"
        },
        {
          "expr": "frigate_camera_process_fps{camera=~\"$camera\"}",
          "legendFormat": "{{camera}} - process",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Detection FPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "fps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "frigate_camera_detection_fps{camera=~\"$camera\"}",
          "legendFormat": "{{camera}}",
          "refId": "A"
        },
        {
          "expr": "frigate_service_total_detection_fps",
          "legendFormat": "total",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Skipped FPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "fps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "frigate_camera_skipped_fps{camera=~\"$camera\"}",
          "legendFormat": "{{camera}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Coral Inference Speed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "frigate_detector_inference_speed",
          "legendFormat": "{{detector}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Intel GPU Usage",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 16 },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "frigate_gpu_gpu_usage",
          "legendFormat": "{{gpu}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Coral Inference Speed",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 16 },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "frigate_detector_inference_speed{detector=\"coral\"}",
          "legendFormat": "Coral",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Camera FPS",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 16 },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "fps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "frigate_service_total_camera_fps",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 16 },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "frigate_service_uptime",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ]
    }
  ]
}
